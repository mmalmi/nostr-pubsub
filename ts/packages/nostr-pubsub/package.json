{
  "name": "nostr-pubsub",
  "version": "0.5.1",
  "description": "Browser-ready Nostr event and source routing primitives",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit && pnpm lint",
    "lint": "node ../../scripts/check-source-size.mjs",
    "test": "vitest run"
  },
  "keywords": [
    "nostr",
    "pubsub",
    "fips",
    "browser"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmalmi/nostr-pubsub.git",
    "directory": "ts/packages/nostr-pubsub"
  },
  "files": [
    "dist",
    "src",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@fips/tcp": "https://github.com/mmalmi/fips-tcp/releases/download/v0.2.0/fips-tcp-0.2.0.tgz"
  },
  "peerDependencies": {
    "nostr-tools": ">=2.17.0 <3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "nostr-tools": "2.23.3",
    "typescript": "^5.3.0",
    "vitest": "^4.0.17"
  }
}
