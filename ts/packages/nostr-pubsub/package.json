{
  "name": "nostr-pubsub",
  "version": "0.1.2",
  "description": "Browser-ready Nostr event and source routing primitives",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "nostr",
    "pubsub",
    "fips",
    "browser"
  ],
  "license": "MIT",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "nostr-tools": ">=2.17.0 <3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "nostr-tools": "2.23.3",
    "typescript": "^5.3.0",
    "vitest": "^4.0.17"
  }
}
